{
  "mcpServers": {
    "obsidian-vault": {
      "type": "sse",
      "url": "https://localhost:27124",
      "headers": {
        "Authorization": "Bearer YOUR_OBSIDIAN_LOCAL_REST_TOKEN"
      }
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    },
    "ddg": {
      "type": "stdio",
      "command": "uvx",
      "args": ["duckduckgo-mcp-server"]
    },
    "fetch": {
      "type": "stdio",
      "command": "uvx",
      "args": ["mcp-server-fetch"]
    }
  }
}
